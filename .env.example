# Neon DB Connection String
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Resend API Key for Email Notifications (Get one for free at resend.com)
RESEND_API_KEY=re_your_resend_api_key

# Recipient Email for Notifications (Defaults to info@banarasisanskriti.com if empty)
NOTIFICATION_EMAIL=info@banarasisanskriti.com
